    def __init__(self, qual_value=6.0, use_mfi=True,
                 star_tune_offset=0, show_prz=True, show_star=True):
        self.qual_value = qual_value
        self.use_mfi = use_mfi
        self.star_tune_offset = star_tune_offset
        self.show_prz = show_prz
        self.show_star = show_star

        # ⭐ PRZ value 배열 (100개, Pine Script와 동일)
        self.value_array = [
            366,454,397,892,660,486,194,918,773,610,
