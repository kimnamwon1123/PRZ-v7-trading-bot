def scan_futures_symbol(detector, symbol):
    """
    해외선물 단일 심볼 신호 스캔
    ⭐ 8시간봉, 일봉만 스캔
    ⭐ 주식과 동일하게 PRZ + 별 둘 다 발동 (przAllowedMarket 통과 종목)
    """
    signals = []

    for tf in FUTURES_TIMEFRAMES:  # ['8h', '1d']
        # 일봉은 10년치, 8h는 1h 리샘플 (암호화폐와 동일한 방식 재활용)
        ohlc = get_crypto_ohlc_data(symbol, tf)

        if ohlc.empty:
            logger.debug(f"데이터 없음: {symbol} {tf}")
            continue

        # ⭐ is_crypto=False → PRZ + 별 둘 다 발동 (주식과 동일)
        signal_type, prz_total, mfi_val, threshold, base_val, star_total, star_th, source = \
            detector.detect_signal(
                symbol=symbol,
                timeframe=tf,
                ohlc_data=ohlc,
                is_korean=False,
                is_crypto=False
            )

        if signal_type != 'NEUTRAL':
            prev_candle_time = str(ohlc.index[-1])
            current_price = ohlc.iloc[-1]['Close']

            last_signal_time = get_last_signal_time(symbol, tf, signal_type)

            if last_signal_time is None or last_signal_time != prev_candle_time:
                signals.append((
                    tf, signal_type, prz_total, threshold,
                    mfi_val, star_total, source, current_price, prev_candle_time
                ))
                logger.info(
                    f"✅ 신호: {symbol} {tf} {signal_type} "
                    f"(PRZ: {prz_total:.2f}, 별: {star_total} / ±{star_th}, 출처: {source})"
                )

    return signals

def scan_all():
    """모든 심볼 스캔"""
    logger.info("=" * 70)
    logger.info(f"🔍 스캔 시작: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    logger.info(f"   qual_value: {QUAL_VALUE}, MFI: {USE_MFI}, "
                f"별 tuneOffset: {STAR_TUNE_OFFSET}, PRZ: {SHOW_PRZ}, 별: {SHOW_STAR}")
    logger.info("=" * 70)

    detector = PRZv7StarDetector(
        qual_value=QUAL_VALUE,
        use_mfi=USE_MFI,
        star_tune_offset=STAR_TUNE_OFFSET,
        show_prz=SHOW_PRZ,
        show_star=SHOW_STAR
    )
    total_new_signals = 0

    # 미국 주식
    us_symbols = get_sp500_symbols()
    logger.info(f"📊 미국 주식 {len(us_symbols)}개 스캔 중...")

    for idx, symbol in enumerate(us_symbols):
        try:
            signals = scan_symbol(detector, symbol, is_korean=False)

            for tf, sig_type, prz_total, threshold, mfi_v, star_v, source, current_price, is_kr, prev_time in signals:
                log_signal(symbol, tf, sig_type, prz_total, threshold,
                          QUAL_VALUE, mfi_v, star_v, source, prev_time)

                update_signal_status(symbol, tf, sig_type, prev_time)
                send_telegram(symbol, tf, sig_type, current_price, prz_total, QUAL_VALUE, mfi_v, is_kr)

                total_new_signals += 1

            if (idx + 1) % 50 == 0:
                logger.info(f"  ✅ {idx + 1}/{len(us_symbols)} 완료...")

        except Exception as e:
            logger.error(f"❌ 스캔 실패 ({symbol}): {e}")
            continue

    logger.info(f"✅ 미국 스캔 완료: {len(us_symbols)}개 심볼")

    # 한국 주식
    kr_symbols = get_korean_stocks()
    logger.info(f"📊 한국 주식 {len(kr_symbols)}개 스캔 중...")

    for idx, symbol in enumerate(kr_symbols):
        try:
            signals = scan_symbol(detector, symbol, is_korean=True)

            for tf, sig_type, prz_total, threshold, mfi_v, star_v, source, current_price, is_kr, prev_time in signals:
                log_signal(symbol, tf, sig_type, prz_total, threshold,
                          QUAL_VALUE, mfi_v, star_v, source, prev_time)

                update_signal_status(symbol, tf, sig_type, prev_time)
                send_telegram(symbol, tf, sig_type, current_price, prz_total, QUAL_VALUE, mfi_v, is_kr)

                total_new_signals += 1

            if (idx + 1) % 10 == 0:
                logger.info(f"  ✅ {idx + 1}/{len(kr_symbols)} 완료...")

        except Exception as e:
            logger.error(f"❌ 스캔 실패 ({symbol}): {e}")
            continue

    logger.info(f"✅ 한국 스캔 완료: {len(kr_symbols)}개 심볼")

    # 해외선물 - 8시간봉/일봉, PRZ + 별 둘 다
    if SCAN_FUTURES:
        futures_list = list(FUTURES_SYMBOLS.keys())
        logger.info(f"📊 해외선물 {len(futures_list)}개 스캔 중 (8시간봉/일봉)...")

        for symbol in futures_list:
            try:
                signals = scan_futures_symbol(detector, symbol)

                for tf, sig_type, prz_total, threshold, mfi_v, star_v, source, current_price, prev_time in signals:
                    log_signal(symbol, tf, sig_type, prz_total, threshold,
                              QUAL_VALUE, mfi_v, star_v, source, prev_time)

                    update_signal_status(symbol, tf, sig_type, prev_time)
                    send_telegram(symbol, tf, sig_type, current_price, prz_total,
                                  QUAL_VALUE, mfi_v, is_korean=False, is_crypto=False, is_futures=True)

                    total_new_signals += 1

            except Exception as e:
                logger.error(f"❌ 해외선물 스캔 실패 ({symbol}): {e}")
                continue

        logger.info(f"✅ 해외선물 스캔 완료: {len(futures_list)}개 심볼")

    # 암호화폐 (비트코인/이더리움) - 8시간봉/일봉, 별 시그널만
    if SCAN_CRYPTO:
        logger.info(f"📊 암호화폐 {len(CRYPTO_SYMBOLS)}개 스캔 중 (8시간봉/일봉, 별 시그널)...")

        for symbol in CRYPTO_SYMBOLS:
            try:
                signals = scan_crypto_symbol(detector, symbol)

                for tf, sig_type, prz_total, threshold, mfi_v, star_v, source, current_price, prev_time in signals:
                    log_signal(symbol, tf, sig_type, prz_total, threshold,
                              QUAL_VALUE, mfi_v, star_v, source, prev_time)

                    update_signal_status(symbol, tf, sig_type, prev_time)
                    send_telegram(symbol, tf, sig_type, current_price, prz_total,
                                  QUAL_VALUE, mfi_v, is_korean=False, is_crypto=True)

                    total_new_signals += 1

            except Exception as e:
                logger.error(f"❌ 암호화폐 스캔 실패 ({symbol}): {e}")
                continue

        logger.info(f"✅ 암호화폐 스캔 완료: {len(CRYPTO_SYMBOLS)}개 심볼")

    logger.info("=" * 70)
    logger.info(f"✅ 스캔 완료 | 신호: {total_new_signals}개")
    logger.info("=" * 70)

    return total_new_signals

