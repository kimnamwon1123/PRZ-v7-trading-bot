def get_tf_minutes(interval):
    """타임프레임을 분 단위로 변환"""
    tf_map = {
        '1m': 1, '3m': 3, '5m': 5, '15m': 15, '30m': 30,
        '1h': 60, '2h': 120, '3h': 180, '4h': 240, '8h': 480,
        '1d': 1440
    }
    return tf_map.get(interval, 60)

