def scan_symbol(detector, symbol, is_korean=False, daily_only=False):
    """단일 심볼 신호 스캔 (PRZ + 별 통합)"""
    signals = []

    # ⭐⭐ 미국주식 1시간봉 제거 (4h/1d만 스캔) + 일봉 전용 종목은 1d만 스캔
    timeframes = ['1d'] if daily_only else ['4h', '1d']

    for tf in timeframes:
        if is_korean and tf != '1d':
            continue

        # ⚡ 슬라이딩 윈도우 최적화로 긴 히스토리 사용 가능
        lookback = LOOKBACK_1D if tf == '1d' else LOOKBACK_INTRADAY
        ohlc = get_ohlc_data(symbol, tf, lookback_days=lookback)

        if ohlc.empty:
            logger.debug(f"데이터 없음: {symbol} {tf}")
            continue

        # ⭐ TradingView 통합 지표와 동일한 신호 감지 (PRZ + 별)
        signal_type, prz_total, mfi_val, threshold, base_val, star_total, star_th, source = \
            detector.detect_signal(
                symbol=symbol,
                timeframe=tf,
                ohlc_data=ohlc,
                is_korean=is_korean
            )

        if signal_type != 'NEUTRAL':
            prev_candle_time = str(ohlc.index[-1])
            current_price = ohlc.iloc[-1]['Close']

            last_signal_time = get_last_signal_time(symbol, tf, signal_type)

            if last_signal_time is None or last_signal_time != prev_candle_time:
                signals.append((
                    tf, signal_type, prz_total, threshold,
                    mfi_val, star_total, source, current_price, is_korean, prev_candle_time
                ))
                logger.info(
                    f"✅ 신호: {symbol} {tf} {signal_type} "
                    f"(PRZ: {prz_total:.2f}, 별: {star_total} / ±{star_th}, 출처: {source})"
                )

    return signals

