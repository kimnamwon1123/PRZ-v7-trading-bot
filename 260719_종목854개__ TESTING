        return False

    try:
        import pytz

        if hasattr(last_candle_time, 'tzinfo') and last_candle_time.tzinfo is not None:
            last_candle_utc = last_candle_time.astimezone(pytz.UTC)
        else:
            last_candle_utc = pytz.UTC.localize(last_candle_time)

        now_utc = datetime.now(pytz.UTC)
        tf_minutes = get_tf_minutes(interval)
        candle_end_time = last_candle_utc + timedelta(minutes=tf_minutes)
        is_completed = now_utc >= candle_end_time

        logger.debug(f"캔들 상태: {last_candle_utc.strftime('%H:%M')} → {candle_end_time.strftime('%H:%M')} (현재: {now_utc.strftime('%H:%M')}) → {'✅' if is_completed else '⏳'}")

        return is_completed
    except Exception as e:
        logger.error(f"캔들 완성 판정 에러: {e}")
        return False

def get_ohlc_data(symbol, interval, lookback_days=60):
    """OHLC 데이터 수집"""
    if not yf:
        logger.error("❌ yfinance 없음")
        return pd.DataFrame()

    try:
        end_date = datetime.now()
        start_date = end_date - timedelta(days=lookback_days)

        ticker = symbol
        if len(symbol) == 6 and symbol.isdigit():
            ticker = f"{symbol}.KS"

        yf_interval = interval

        df = yf.download(
            ticker,
            start=start_date,
            end=end_date,
            interval=yf_interval,
            progress=False,
            timeout=30
        )

        if df.empty:
            logger.debug(f"데이터 없음: {symbol} {interval}")
            return pd.DataFrame()

        if isinstance(df.columns, pd.MultiIndex):
            df.columns = df.columns.droplevel(1)

        df.columns = df.columns.str.lower()

        required_cols = ['open', 'high', 'low', 'close', 'volume']
        if not all(col in df.columns for col in required_cols):
            logger.error(f"필수 컬럼 부족: {symbol} {interval}")
            return pd.DataFrame()

        df = df[required_cols].copy()
        df.columns = ['Open', 'High', 'Low', 'Close', 'Volume']

        if df.isnull().any().any():
            df.dropna(inplace=True)

        if df.empty or len(df) < 5:
            logger.debug(f"데이터 부족: {symbol} {interval}")
            return pd.DataFrame()

        # ⭐ Pine Script barstate.isconfirmed 방식
        last_candle_time = df.index[-1]

        if is_candle_completed(last_candle_time, interval):
            logger.debug(f"✅ {symbol} {interval}: 현재 캔들 완성, 포함 ({len(df)}개 바)")
            return df
        else:
            logger.debug(f"⏳ {symbol} {interval}: 현재 캔들 미완성, 제외 ({len(df)-1}개 바)")
            df_prev = df.iloc[:-1]

            if len(df_prev) < 5:
                logger.debug(f"분석 가능한 캔들 부족: {symbol} {interval}")
                return pd.DataFrame()

            return df_prev

    except Exception as e:
        logger.error(f"❌ 데이터 수집 실패 ({symbol}, {interval}): {e}")
        return pd.DataFrame()

def _resample_8h(df):
    """
    1시간봉 → 8시간봉 리샘플 (UTC 00:00/08:00/16:00 경계, 트레이딩뷰와 동일)
    pandas 버전에 따라 '8h'(신) 또는 '8H'(구) 규칙 사용
    """
    # 인덱스를 UTC로 정규화
    if df.index.tz is None:
        df.index = df.index.tz_localize('UTC')
    else:
        df.index = df.index.tz_convert('UTC')

    agg = {'Open': 'first', 'High': 'max', 'Low': 'min', 'Close': 'last', 'Volume': 'sum'}
    try:
        out = df.resample('8h', origin='epoch').agg(agg)
    except (ValueError, TypeError):
        out = df.resample('8H', origin='epoch').agg(agg)
    return out.dropna()

def get_crypto_ohlc_data(symbol, tf):
    """
    암호화폐 OHLC 수집 (비트코인/이더리움)
    - 1d: yfinance 일봉 직접 수집 (최대 10년치)
    - 8h: yfinance 1h 수집 후 8시간봉으로 리샘플 (yfinance는 8h 미지원)
    """
    if not yf:
        logger.error("❌ yfinance 없음")
        return pd.DataFrame()

    try:
        end_date = datetime.now()

        if tf == '1d':
            start_date = end_date - timedelta(days=LOOKBACK_1D)
            fetch_interval = '1d'
        else:  # '8h' → 1h 수집 후 리샘플
            start_date = end_date - timedelta(days=CRYPTO_8H_LOOKBACK)
            fetch_interval = '1h'

        # ⭐ 다운로드 (1h는 실패 시 기간을 절반씩 줄여 최대 3회 재시도)
        #    yfinance는 긴 기간의 1h 요청에서 간헐적으로 실패함 (_NoValueType 버그)
        df = pd.DataFrame()
        attempt_days = (end_date - start_date).days
        for attempt in range(3):
            try:
                df = yf.download(
                    symbol,
                    start=end_date - timedelta(days=attempt_days),
                    end=end_date,
                    interval=fetch_interval,
                    progress=False,
                    timeout=30
                )
            except Exception:
                df = pd.DataFrame()

            if df is not None and not df.empty:
                break

            if fetch_interval != '1h':
                break  # 일봉은 재시도 불필요

            attempt_days = attempt_days // 2  # 400 → 200 → 100일
            logger.debug(f"⚠️ {symbol} {tf}: 1h 다운로드 실패, {attempt_days}일로 재시도...")

        if df is None or df.empty:
            logger.debug(f"데이터 없음: {symbol} {tf}")
            return pd.DataFrame()

        if isinstance(df.columns, pd.MultiIndex):
            df.columns = df.columns.droplevel(1)

        df.columns = df.columns.str.lower()

        required_cols = ['open', 'high', 'low', 'close', 'volume']
        if not all(col in df.columns for col in required_cols):
            logger.error(f"필수 컬럼 부족: {symbol} {tf}")
            return pd.DataFrame()

        df = df[required_cols].copy()
        df.columns = ['Open', 'High', 'Low', 'Close', 'Volume']
        df.dropna(inplace=True)

        if df.empty:
            return pd.DataFrame()

        # ⭐ 8h는 1h를 리샘플
        if tf == '8h':
            df = _resample_8h(df)

        if len(df) < 5:
            logger.debug(f"데이터 부족: {symbol} {tf}")
            return pd.DataFrame()

        # ⭐ Pine barstate.isconfirmed 방식 (미완성 캔들 제외)
        last_candle_time = df.index[-1]
        if is_candle_completed(last_candle_time, tf):
            logger.debug(f"✅ {symbol} {tf}: 현재 캔들 완성, 포함 ({len(df)}개 바)")
            return df
        else:
            logger.debug(f"⏳ {symbol} {tf}: 현재 캔들 미완성, 제외 ({len(df)-1}개 바)")
            df_prev = df.iloc[:-1]
            if len(df_prev) < 5:
                return pd.DataFrame()
            return df_prev

    except Exception as e:
        logger.error(f"❌ 암호화폐 데이터 수집 실패 ({symbol}, {tf}): {e}")
        return pd.DataFrame()

