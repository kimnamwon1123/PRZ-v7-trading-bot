    try:
        if is_crypto:
            market = "[코인]"
        elif is_futures:
            market = "[해외선물]"
        elif is_korean:
            market = "[한국주식]"
        else:
            market = "[미국주식]"

        if signal_type == 'LONG':
            signal_str = "🔵 PRZ 롱(매수) 시그널"
        else:
            signal_str = "🔴 PRZ 숏(매도) 시그널"

        tf_kr = {
            '1h': '1시간봉',
            '4h': '4시간봉',
